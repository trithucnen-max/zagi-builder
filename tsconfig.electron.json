{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist-electron",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "electron/**/*",
    "src/services/**/*",
    "src/utils/**/*",
    "src/models/**/*",
    "src/configs/**/*"
  ],
  "exclude": [
    "src/ui/**/*",
    "node_modules",
    "dist",
    "dist-electron"
  ]
}

