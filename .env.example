# ─────────────────────────────────────────────────────────────────────────────
# ZAGI Environment Variables — EXAMPLE FILE
# Sao chép file này thành .env và điền giá trị thực.
# ⚠️  KHÔNG commit .env vào git (đã có trong .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# License API Secret — được dùng trong main process (Electron)
# Thay thế cho API_SECRET hardcoded trong LicenseManager.ts
LICENSE_API_SECRET=your_actual_secret_here

# License API Endpoint (tùy chọn — có giá trị mặc định trong LicenseManager)
# LICENSE_API_URL=https://your-custom-endpoint.com/exec

# Môi trường (development | production)
NODE_ENV=development
